# ============================================================
# Crosscheck — environment configuration
# Copy this file to `.env` and fill in what you have.
# The app runs with ZERO config (offline demo on the bundled
# cached report). Add an LLM to get live reasoning. Add Foundry
# IQ settings + PROVIDER=foundry to run on a real knowledge base.
# ============================================================

# ---- Knowledge retrieval provider ----
# mock    = retrieve over the bundled synthetic corpus (default, no cloud needed)
# foundry = retrieve via a real Foundry IQ knowledge base (Azure AI Search agentic retrieval)
PROVIDER=mock

# ---- Reasoning LLM: Azure OpenAI (recommended — all-Microsoft, on-theme) ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# ---- Reasoning LLM: OpenAI-compatible fallback (used only if the Azure vars above are empty) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ---- Foundry IQ (Azure AI Search agentic retrieval) — only needed when PROVIDER=foundry ----
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_KNOWLEDGE_BASE=crosscheck-kb
AZURE_SEARCH_API_VERSION=2025-08-01-preview
# Optional: paste the exact retrieve URL from the Foundry IQ portal if the
# preview path/version differs from the default the provider builds.
AZURE_SEARCH_RETRIEVE_URL=

# ---- Behavior ----
# If true (or if no LLM is configured), serve the bundled samples/cached_report.json
# instead of calling an LLM. Lets the UI + demo work with zero credentials.
OFFLINE_DEMO=false
MAX_PASSAGES=24
